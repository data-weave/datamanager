{
    "compilerOptions": {
        "target": "es2016",
        "lib": ["es6"],
        "module": "commonjs",
        "resolveJsonModule": true,
        "allowJs": true,
        "declaration": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@data-weave/datamanager": ["./packages/datamanager/src"],
            "@data-weave/backend-firestore": ["./packages/backend-firestore/src"],
            "@data-weave/backend-firestore-admin": ["./packages/backend-firestore-admin/src"],
            "@data-weave/datamanager-firestore-mobx": ["./packages/datamanager-firestore-mobx/src"]
        }
    }
}
